  { "id": "a11-040", "english": "The man works a lot.", "german": "Der Mann arbeitet viel.", "level": "A1.1" },

  { "id": "a11-041", "english": "Excuse me, where is the train station?", "german": "Entschuldigung, wo ist der Bahnhof?", "level": "A1.1" },
  { "id": "a11-042", "english": "Where is the pharmacy?", "german": "Wo ist die Apotheke?", "level": "A1.1" },
