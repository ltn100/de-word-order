[
  { "id": "a11-001", "english": "Hello, my name is Anna.", "german": "Hallo, ich heiße Anna.", "level": "A1.1" },
  { "id": "a11-002", "english": "Good morning, how are you?", "german": "Guten Morgen, wie geht es Ihnen?", "level": "A1.1" },
  { "id": "a11-003", "english": "I am fine, thank you.", "german": "Mir geht es gut, danke.", "level": "A1.1" },
  { "id": "a11-004", "english": "Good evening!", "german": "Guten Abend!", "level": "A1.1" },
  { "id": "a11-005", "english": "Goodbye!", "german": "Auf Wiedersehen!", "level": "A1.1" },
  { "id": "a11-006", "english": "See you soon!", "german": "Bis bald!", "level": "A1.1" },
  { "id": "a11-007", "english": "Good night!", "german": "Gute Nacht!", "level": "A1.1" },
  { "id": "a11-008", "english": "Nice to meet you!", "german": "Freut mich!", "level": "A1.1" },
  { "id": "a11-009", "english": "What is your name?", "german": "Wie heißen Sie?", "level": "A1.1" },
  { "id": "a11-010", "english": "My name is Thomas.", "german": "Ich heiße Thomas.", "level": "A1.1" },

  { "id": "a11-011", "english": "Where do you come from?", "german": "Woher kommen Sie?", "level": "A1.1" },
  { "id": "a11-012", "english": "I come from Germany.", "german": "Ich komme aus Deutschland.", "level": "A1.1" },
  { "id": "a11-013", "english": "I come from Austria.", "german": "Ich komme aus Österreich.", "level": "A1.1" },
  { "id": "a11-014", "english": "She comes from Switzerland.", "german": "Sie kommt aus der Schweiz.", "level": "A1.1" },
  { "id": "a11-015", "english": "He comes from France.", "german": "Er kommt aus Frankreich.", "level": "A1.1" },
  { "id": "a11-016", "english": "Where do you live?", "german": "Wo wohnen Sie?", "level": "A1.1" },
  { "id": "a11-017", "english": "I live in Munich.", "german": "Ich wohne in München.", "level": "A1.1" },
