[
  { "id": "a12-001", "english": "What time is it?", "german": "Wie spät ist es?", "level": "A1.2" },
  { "id": "a12-002", "english": "It is eight o'clock.", "german": "Es ist acht Uhr.", "level": "A1.2" },
  { "id": "a12-003", "english": "It is half past eight.", "german": "Es ist halb neun.", "level": "A1.2" },
  { "id": "a12-004", "english": "It is quarter past nine.", "german": "Es ist Viertel nach neun.", "level": "A1.2" },
  { "id": "a12-005", "english": "It is quarter to ten.", "german": "Es ist Viertel vor zehn.", "level": "A1.2" },
  { "id": "a12-006", "english": "I get up at seven o'clock.", "german": "Ich stehe um sieben Uhr auf.", "level": "A1.2", "hints": { "separable": ["aufstehen"] } },
  { "id": "a12-007", "english": "She gets up early.", "german": "Sie steht früh auf.", "level": "A1.2", "hints": { "separable": ["aufstehen"] } },
  { "id": "a12-008", "english": "Work begins at nine o'clock.", "german": "Die Arbeit fängt um neun Uhr an.", "level": "A1.2", "hints": { "separable": ["anfangen"] } },
  { "id": "a12-009", "english": "The meeting ends at five.", "german": "Die Besprechung hört um fünf auf.", "level": "A1.2", "hints": { "separable": ["aufhören"] } },
  { "id": "a12-010", "english": "He watches TV in the evening.", "german": "Er sieht abends fern.", "level": "A1.2", "hints": { "separable": ["fernsehen"] } },

  { "id": "a12-011", "english": "My father works at the bank.", "german": "Mein Vater arbeitet bei der Bank.", "level": "A1.2" },
  { "id": "a12-012", "english": "My mother is a nurse.", "german": "Meine Mutter ist Krankenschwester.", "level": "A1.2" },
  { "id": "a12-013", "english": "My brother studies in Berlin.", "german": "Mein Bruder studiert in Berlin.", "level": "A1.2" },
  { "id": "a12-014", "english": "My sister goes to school.", "german": "Meine Schwester geht zur Schule.", "level": "A1.2", "hints": { "contractions": ["zur"] } },
  { "id": "a12-015", "english": "My parents live in Munich.", "german": "Meine Eltern wohnen in München.", "level": "A1.2" },
  { "id": "a12-016", "english": "His wife is a doctor.", "german": "Seine Frau ist Ärztin.", "level": "A1.2" },
  { "id": "a12-017", "english": "Her husband works at home.", "german": "Ihr Mann arbeitet zu Hause.", "level": "A1.2" },
  { "id": "a12-018", "english": "Our children are at school.", "german": "Unsere Kinder sind in der Schule.", "level": "A1.2" },
  { "id": "a12-019", "english": "Your daughter is very nice.", "german": "Ihre Tochter ist sehr nett.", "level": "A1.2" },
  { "id": "a12-020", "english": "Their son is a student.", "german": "Ihr Sohn ist Student.", "level": "A1.2" },

  { "id": "a12-021", "english": "I can swim.", "german": "Ich kann schwimmen.", "level": "A1.2" },
  { "id": "a12-022", "english": "She can speak German.", "german": "Sie kann Deutsch sprechen.", "level": "A1.2" },
  { "id": "a12-023", "english": "Can you help me?", "german": "Kannst du mir helfen?", "level": "A1.2" },
  { "id": "a12-024", "english": "I cannot come today.", "german": "Ich kann heute nicht kommen.", "level": "A1.2" },
  { "id": "a12-025", "english": "I have to work today.", "german": "Ich muss heute arbeiten.", "level": "A1.2" },
  { "id": "a12-026", "english": "We have to go to the doctor.", "german": "Wir müssen zum Arzt gehen.", "level": "A1.2", "hints": { "contractions": ["zum"] } },
  { "id": "a12-027", "english": "She has to learn German.", "german": "Sie muss Deutsch lernen.", "level": "A1.2" },
  { "id": "a12-028", "english": "You have to take the medication.", "german": "Du musst die Medizin nehmen.", "level": "A1.2" },
  { "id": "a12-029", "english": "I want to go to the cinema.", "german": "Ich will ins Kino gehen.", "level": "A1.2", "hints": { "contractions": ["ins"] } },
  { "id": "a12-030", "english": "She wants to visit her parents.", "german": "Sie will ihre Eltern besuchen.", "level": "A1.2" },

  { "id": "a12-031", "english": "Do you want to come along?", "german": "Willst du mitkommen?", "level": "A1.2", "hints": { "separable": ["mitkommen"] } },
  { "id": "a12-032", "english": "We want to eat pizza.", "german": "Wir wollen Pizza essen.", "level": "A1.2" },
  { "id": "a12-033", "english": "One is not allowed to smoke here.", "german": "Hier darf man nicht rauchen.", "level": "A1.2" },
  { "id": "a12-034", "english": "One may park here.", "german": "Hier darf man parken.", "level": "A1.2" },
  { "id": "a12-035", "english": "May I ask a question?", "german": "Darf ich eine Frage stellen?", "level": "A1.2" },
  { "id": "a12-036", "english": "You should drink more water.", "german": "Du sollst mehr Wasser trinken.", "level": "A1.2" },
  { "id": "a12-037", "english": "You should stay in bed.", "german": "Du sollst im Bett bleiben.", "level": "A1.2", "hints": { "contractions": ["im"] } },
  { "id": "a12-038", "english": "I should call my mother.", "german": "Ich soll meine Mutter anrufen.", "level": "A1.2", "hints": { "separable": ["anrufen"] } },
  { "id": "a12-039", "english": "What should I bring?", "german": "Was soll ich mitbringen?", "level": "A1.2", "hints": { "separable": ["mitbringen"] } },
  { "id": "a12-040", "english": "I cannot come, I have to work.", "german": "Ich kann nicht kommen, ich muss arbeiten.", "level": "A1.2" },

  { "id": "a12-041", "english": "I call my friend.", "german": "Ich rufe meinen Freund an.", "level": "A1.2", "hints": { "separable": ["anrufen"] } },
  { "id": "a12-042", "english": "She shops at the supermarket.", "german": "Sie kauft im Supermarkt ein.", "level": "A1.2", "hints": { "separable": ["einkaufen"], "contractions": ["im"] } },
  { "id": "a12-043", "english": "He tidies up his room.", "german": "Er räumt sein Zimmer auf.", "level": "A1.2", "hints": { "separable": ["aufräumen"] } },
  { "id": "a12-044", "english": "I invite you to dinner.", "german": "Ich lade dich zum Abendessen ein.", "level": "A1.2", "hints": { "separable": ["einladen"], "contractions": ["zum"] } },
  { "id": "a12-045", "english": "The train leaves at two o'clock.", "german": "Der Zug fährt um zwei Uhr ab.", "level": "A1.2", "hints": { "separable": ["abfahren"] } },
  { "id": "a12-046", "english": "She puts on her jacket.", "german": "Sie zieht ihre Jacke an.", "level": "A1.2", "hints": { "separable": ["anziehen"] } },
  { "id": "a12-047", "english": "He takes off his shoes.", "german": "Er zieht seine Schuhe aus.", "level": "A1.2", "hints": { "separable": ["ausziehen"] } },
  { "id": "a12-048", "english": "Call me!", "german": "Ruf mich an!", "level": "A1.2", "hints": { "separable": ["anrufen"] } },
  { "id": "a12-049", "english": "I have to get up at six o'clock.", "german": "Ich muss um sechs Uhr aufstehen.", "level": "A1.2" },
  { "id": "a12-050", "english": "We want to watch TV.", "german": "Wir wollen fernsehen.", "level": "A1.2" },

  { "id": "a12-051", "english": "On the weekend I play soccer.", "german": "Am Wochenende spiele ich Fußball.", "level": "A1.2", "hints": { "contractions": ["am"] } },
  { "id": "a12-052", "english": "On Monday I have a meeting.", "german": "Am Montag habe ich eine Besprechung.", "level": "A1.2", "hints": { "contractions": ["am"] } },
  { "id": "a12-053", "english": "In the morning I drink coffee.", "german": "Morgens trinke ich Kaffee.", "level": "A1.2" },
  { "id": "a12-054", "english": "In the evening we eat together.", "german": "Abends essen wir zusammen.", "level": "A1.2" },
  { "id": "a12-055", "english": "I work from nine to five.", "german": "Ich arbeite von neun bis fünf.", "level": "A1.2" },
  { "id": "a12-056", "english": "My birthday is on the fifth of May.", "german": "Mein Geburtstag ist am fünften Mai.", "level": "A1.2", "hints": { "contractions": ["am"] } },
  { "id": "a12-057", "english": "The party is on the third of October.", "german": "Die Party ist am dritten Oktober.", "level": "A1.2", "hints": { "contractions": ["am"] } },
  { "id": "a12-058", "english": "Can you come to my party?", "german": "Kannst du zu meiner Party kommen?", "level": "A1.2" },
  { "id": "a12-059", "english": "We celebrate Christmas together.", "german": "Wir feiern Weihnachten zusammen.", "level": "A1.2" },
  { "id": "a12-060", "english": "Thank you for the invitation.", "german": "Danke für die Einladung.", "level": "A1.2" },

  { "id": "a12-061", "english": "The book is on the table.", "german": "Das Buch liegt auf dem Tisch.", "level": "A1.2" },
  { "id": "a12-062", "english": "The keys are in the drawer.", "german": "Die Schlüssel sind in der Schublade.", "level": "A1.2" },
  { "id": "a12-063", "english": "The computer is on the desk.", "german": "Der Computer steht auf dem Schreibtisch.", "level": "A1.2" },
  { "id": "a12-064", "english": "The picture hangs on the wall.", "german": "Das Bild hängt an der Wand.", "level": "A1.2" },
  { "id": "a12-065", "english": "The cat sits under the table.", "german": "Die Katze sitzt unter dem Tisch.", "level": "A1.2" },
  { "id": "a12-066", "english": "I work with my colleagues.", "german": "Ich arbeite mit meinen Kollegen.", "level": "A1.2" },
  { "id": "a12-067", "english": "She drives to work by car.", "german": "Sie fährt mit dem Auto zur Arbeit.", "level": "A1.2", "hints": { "contractions": ["zur"] } },
  { "id": "a12-068", "english": "Can you send me an email?", "german": "Kannst du mir eine E-Mail schicken?", "level": "A1.2" },
  { "id": "a12-069", "english": "I have a meeting at ten.", "german": "Ich habe um zehn eine Besprechung.", "level": "A1.2" },
  { "id": "a12-070", "english": "I work in a large office.", "german": "Ich arbeite in einem großen Büro.", "level": "A1.2" },

  { "id": "a12-071", "english": "My head hurts.", "german": "Mein Kopf tut weh.", "level": "A1.2" },
  { "id": "a12-072", "english": "My back hurts.", "german": "Mein Rücken tut weh.", "level": "A1.2" },
  { "id": "a12-073", "english": "I have a cold.", "german": "Ich habe eine Erkältung.", "level": "A1.2" },
  { "id": "a12-074", "english": "I have a stomach ache.", "german": "Ich habe Bauchschmerzen.", "level": "A1.2" },
  { "id": "a12-075", "english": "I am sick and cannot work.", "german": "Ich bin krank und kann nicht arbeiten.", "level": "A1.2" },
  { "id": "a12-076", "english": "She has to take the tablets.", "german": "Sie muss die Tabletten nehmen.", "level": "A1.2" },
  { "id": "a12-077", "english": "Get well soon!", "german": "Gute Besserung!", "level": "A1.2" },
  { "id": "a12-078", "english": "What is wrong with you?", "german": "Was fehlt Ihnen?", "level": "A1.2" },
  { "id": "a12-079", "english": "I feel better today.", "german": "Mir geht es heute besser.", "level": "A1.2" },
  { "id": "a12-080", "english": "I am very tired.", "german": "Ich bin sehr müde.", "level": "A1.2" },

  { "id": "a12-081", "english": "Drink a lot of water!", "german": "Trink viel Wasser!", "level": "A1.2" },
  { "id": "a12-082", "english": "Take this medicine!", "german": "Nimm diese Medizin!", "level": "A1.2" },
  { "id": "a12-083", "english": "Go to the doctor!", "german": "Geh zum Arzt!", "level": "A1.2", "hints": { "contractions": ["zum"] } },
  { "id": "a12-084", "english": "Stay at home!", "german": "Bleib zu Hause!", "level": "A1.2" },
  { "id": "a12-085", "english": "Sit down!", "german": "Setzen Sie sich!", "level": "A1.2" },
  { "id": "a12-086", "english": "Be quiet!", "german": "Sei ruhig!", "level": "A1.2" },
  { "id": "a12-087", "english": "Come with me!", "german": "Komm mit!", "level": "A1.2" },
  { "id": "a12-088", "english": "Wait a moment!", "german": "Warte einen Moment!", "level": "A1.2" },
  { "id": "a12-089", "english": "Open the window!", "german": "Öffne das Fenster!", "level": "A1.2" },
  { "id": "a12-090", "english": "Read the text!", "german": "Lies den Text!", "level": "A1.2" },

  { "id": "a12-091", "english": "Where were you yesterday?", "german": "Wo warst du gestern?", "level": "A1.2" },
  { "id": "a12-092", "english": "I was at the cinema.", "german": "Ich war im Kino.", "level": "A1.2", "hints": { "contractions": ["im"] } },
  { "id": "a12-093", "english": "The weather was nice.", "german": "Das Wetter war schön.", "level": "A1.2" },
  { "id": "a12-094", "english": "The party was great!", "german": "Die Party war toll!", "level": "A1.2" },
  { "id": "a12-095", "english": "We had a lot of fun.", "german": "Wir hatten viel Spaß.", "level": "A1.2" },
  { "id": "a12-096", "english": "I had no time.", "german": "Ich hatte keine Zeit.", "level": "A1.2" },
  { "id": "a12-097", "english": "She had a headache.", "german": "Sie hatte Kopfschmerzen.", "level": "A1.2" },
  { "id": "a12-098", "english": "Yesterday was Sunday.", "german": "Gestern war Sonntag.", "level": "A1.2" },
  { "id": "a12-099", "english": "The food was delicious.", "german": "Das Essen war lecker.", "level": "A1.2" },
  { "id": "a12-100", "english": "I was in Berlin last week.", "german": "Ich war letzte Woche in Berlin.", "level": "A1.2" }
